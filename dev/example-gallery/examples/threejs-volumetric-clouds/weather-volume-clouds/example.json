{
  "title": "Weather Volume Clouds",
  "description": "A large-world bounded cloud raymarch with authored low, middle, and high weather channels, 3D base and detail volumes, turbulence distortion, profile-shaped density, directional self-shadowing, atmospheric composition, and temporal reconstruction.",
  "backend": "WebGL2 / GLSL3 volumetric reconstruction",
  "techniques": [
    "authored multi-layer weather-channel density",
    "bounded layer interval selection",
    "128-cubed base shape and 32-cubed detail erosion",
    "curl-texture turbulence displacement",
    "front-to-back energy-conserving integration",
    "directional optical-depth march",
    "low-resolution temporal reconstruction"
  ],
  "defaultViewport": {
    "width": 1440,
    "height": 900
  },
  "defaultDpr": 1,
  "debugModes": [
    { "value": "final", "label": "Final" },
    { "value": "weather", "label": "Weather channels" },
    { "value": "base-shape", "label": "Base shape" },
    { "value": "detail", "label": "Detail modifier" },
    { "value": "density", "label": "Layer density" },
    { "value": "transmittance", "label": "Transmittance" },
    { "value": "lighting", "label": "Lighting" },
    { "value": "history", "label": "History rejection" }
  ],
  "controls": [
    "orbit",
    "pause",
    "timeScale",
    "dpr",
    "debugMode",
    "capture"
  ]
}
