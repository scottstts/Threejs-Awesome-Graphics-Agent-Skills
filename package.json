{
  "name": "threejs-gamedev-mega-skills",
  "version": "0.1.0",
  "description": "Expert procedural geometry, materials, shaders, atmosphere, effects, and image-pipeline skills for Three.js coding agents.",
  "license": "MIT",
  "author": "Scott",
  "keywords": [
    "agent-skills",
    "threejs",
    "three.js",
    "codex",
    "claude-code",
    "cursor",
    "copilot",
    "gemini-cli",
    "windsurf",
    "procedural-graphics",
    "webgpu",
    "tsl",
    "glsl",
    "shaders",
    "volumetric-rendering",
    "post-processing"
  ],
  "type": "module",
  "bin": {
    "threejs-gamedev-mega-skills": "bin/threejs-gamedev-mega-skills.mjs"
  },
  "files": [
    ".codex-plugin/",
    "bin/",
    "skills/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "validate": "node scripts/validate-pack.mjs",
    "test": "npm run validate && npm run test:references && npm run test:installer && npm run test:gallery",
    "dev:examples": "node dev/example-gallery/server.mjs --open",
    "dev:examples:no-open": "node dev/example-gallery/server.mjs",
    "dev:examples:fixture": "node dev/example-gallery/server.mjs --open --include-fixtures",
    "capture:examples": "node scripts/capture-examples.mjs",
    "audit:sources": "node scripts/validate-source-traces.mjs",
    "test:references": "node scripts/test-reference-examples.mjs",
    "test:installer": "node scripts/test-installer.mjs",
    "test:gallery": "node scripts/test-example-gallery.mjs",
    "check:freshness": "node scripts/check-three-freshness.mjs",
    "test:all": "npm test && npm run check:freshness",
    "prepack": "npm run test:all",
    "prepublishOnly": "npm run check:freshness"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "three": "^0.184.0",
    "yaml": "^2.9.0"
  }
}
